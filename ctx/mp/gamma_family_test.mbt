///|
fn assert_gamma_complex_close(
  z : @mpc.RawMpc,
  expected_real : String,
  expected_imag : String,
  tolerance : String,
) -> Unit raise {
  assert_close_mpf_str(z.real, expected_real, tolerance)
  assert_close_mpf_str(z.imag, expected_imag, tolerance)
}

///|
test "real gamma reciprocal log and factorial match high-precision mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let x = ctx.parse("2.75")
  assert_close_mpf_str(
    ctx.gamma(x),
    "1.6083594219855456592319415231637938164922515131418426772395311065053925410601728438737887437820760248891025617312",
    "2e-101",
  )
  assert_close_mpf_str(
    ctx.reciprocal_gamma(x),
    "0.6217515726462956046301607217911143720197968539499151956236634147195919723525391318058190936587912103871111774",
    "2e-101",
  )
  assert_close_mpf_str(
    ctx.log_gamma(x),
    "0.47521466691493713031310246639542886174224206494616827178534049928637298628587397360830206277201405089924759152",
    "2e-102",
  )
  assert_close_mpf_str(
    ctx.factorial(x),
    "4.4229884104602505628878391887004329953536916611400673624087105428898294879154753206529190454007090684450320443",
    "2e-100",
  )
}

///|
test "real gamma derivatives and continuations match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let x = ctx.parse("2.75")
  assert_close_mpf_str(
    ctx.digamma(x),
    "0.81890102497543259227787514194472406873468686542876831122442693755076437236111758632138513029481762661234291485",
    "2e-101",
  )
  assert_close_mpf_str(
    ctx.polygamma(2, x),
    "-0.18871463303130122305348220468309107817269583966485297145400822659115821949840647363444150976226716028995826011",
    "2e-101",
  )
  assert_close_mpf_str(
    ctx.harmonic(x),
    "1.7597530535133290892480235956634901361404825650050555463938305360719957355024186208946958299502007397633379985",
    "2e-100",
  )
  assert_close_mpf_str(
    ctx.fibonacci(x),
    "1.763891791467279460989902224959175508453280497255135073453878090409388797916723880173530711489720188224851145",
    "2e-100",
  )
  assert_close_mpf_str(
    ctx.eta(x),
    "0.88553626739344381804584178582061755062182781211842754234921625328555232619585165765070278322796198935659085452",
    "2e-101",
  )
  assert_close_mpf_str(
    ctx.bernoulli_number(20),
    "-529.12424242424242424242424242424242424242424242424242424242424242424242424242424242424242424242424242424242424",
    "2e-98",
  )
}

///|
test "gamma pole and reciprocal-zero semantics are structured" {
  let ctx = MPContext::new(240, Nearest)
  for n in [0, -1, -2, -17] {
    let x = ctx.from_int(n)
    @debug.assert_eq(ctx.reciprocal_gamma(x), @mpf.RawMpf::zero())
    try ctx.gamma(x) catch {
      PoleError(_) => ()
      _ => fail("unexpected gamma pole error")
    } noraise {
      _ => fail("expected gamma pole")
    }
  }
  try ctx.polygamma(-1, ctx.from_int(2)) catch {
    ValueError(_) => ()
    _ => fail("unexpected polygamma order error")
  } noraise {
    _ => fail("expected negative polygamma order error")
  }
  try ctx.factorial(ctx.from_int(-1)) catch {
    PoleError(_) => ()
    _ => fail("unexpected factorial pole error")
  } noraise {
    _ => fail("expected factorial pole")
  }
}

///|
test "complex gamma family matches high-precision mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_gamma_complex_close(
    ctx.complex_reciprocal_gamma(z),
    "1.49274589254045963714484561220536110692883463775678836757403007020240788897742216632075755885000260863047",
    "-0.135610531444358633927965914205090714799660003915262559679601254511966425892103898177118077025412392780653",
    "2e-99",
  )
  assert_gamma_complex_close(
    ctx.complex_log_gamma(z),
    "-0.404726900299940762600685998085695119372375275634440395327540966903017204425882288625895442604110183220831",
    "0.0905976705941058288206075495128889785337679724037469982464769628311953966603363905944941545911952425325065",
    "2e-99",
  )
  assert_gamma_complex_close(
    ctx.complex_factorial(z),
    "0.875798873183328895244619424730476451470676532150880626788040004130210283367313733379656972131844109685805",
    "-0.422866646308409980243534222628671577768418311331728286909567692629964492568738379596453920673123546006859",
    "2e-99",
  )
}

///|
test "complex gamma derivatives and continuations match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_gamma_complex_close(
    ctx.complex_digamma(z),
    "0.0636023757430216537685260618026218246006404313426797597968857175704861980344561163635771276717815587224467",
    "-0.75001317899832357610182423710286701961689566801516062286157495233120605193353830204113829666452648545706",
    "2e-99",
  )
  assert_gamma_complex_close(
    ctx.complex_polygamma(2, z),
    "-0.156974375815124119838771622717896592866676230033067737444063519284310885888118662005142765396508900490981",
    "-0.827495564937966069686579771437140723090715467487247486817323640360120992812030198016249915261159955429684",
    "2e-98",
  )
  assert_gamma_complex_close(
    ctx.complex_harmonic(z),
    "1.22905333476220157319856756364973013799574094375319159389677059951417745422388549318287713213999889647237",
    "-0.397072002527735340807706590044043490205130962132807681685104364095911934286479478511726531958644132515883",
    "2e-98",
  )
  assert_gamma_complex_close(
    ctx.complex_fibonacci(z),
    "1.30656597180310744755517144601556194281661293710669666664593857721378362780322170951183556743230680469171",
    "0.885094380390464486177804796394388827072125991801232498794804143296646423205887371121252259024892989901979",
    "2e-98",
  )
  assert_gamma_complex_close(
    ctx.complex_eta(z),
    "0.748841196491565644713253198069866121167197221141289114710749783979072518705367534792800600209528670936342",
    "-0.106929529726223534312057451876036323747067793873718196970840186270069504159915960821904582375864993122074",
    "2e-98",
  )
}

///|
test "complex log-gamma branch and reciprocal zeros match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let minus_half = ctx.complex(ctx.parse("-0.5"), @mpf.RawMpf::zero())
  assert_gamma_complex_close(
    ctx.complex_log_gamma(minus_half),
    "1.26551212348464539648894579713470592389914754081791103987749154522946250691210775549767496213416354139301",
    "-3.14159265358979323846264338327950288419716939937510582097494459230781640628620899862803482534211706798215",
    "2e-100",
  )
  @debug.assert_eq(
    ctx.complex_reciprocal_gamma(
      ctx.complex(ctx.from_int(-2), @mpf.RawMpf::zero()),
    ),
    @mpc.RawMpc::zero(),
  )
  assert_gamma_complex_close(
    ctx.complex_factorial(minus_half),
    "1.77245385090551602729816748334114518279754945612238712821380778985291128459103218137495065673854466541623",
    "0",
    "2e-100",
  )
}
