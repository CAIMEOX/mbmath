///|
fn assert_integral_complex_close(
  z : @mpc.RawMpc,
  expected_real : String,
  expected_imag : String,
  tolerance : String,
) -> Unit raise {
  assert_close_mpf_str(z.real, expected_real, tolerance)
  assert_close_mpf_str(z.imag, expected_imag, tolerance)
}

///|
test "real exponential integral positive asymptotic matches mpmath" {
  let ctx = MPContext::new(360, Nearest)
  assert_close_mpf_str(
    ctx.exponential_integral_ei(ctx.from_int(20000)),
    "3.87819628250450109302738700855018194706984769750187598378621583660541294765012106575681742733401683560818255331855e+8681",
    "2e8576",
  )
}

///|
test "real exponential integral negative cancellation matches mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let got = ctx.exponential_integral_ei(ctx.from_int(-200))
  assert_close_mpf_str(
    got, "-6.885226106307635597710817482455792973836808693330250988066462408134800621841274909985690580563900548254804031442225e-90",
    "2e-195",
  )
}

///|
test "complex exponential integral series and asymptotic regions match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  assert_integral_complex_close(
    ctx.complex_exponential_integral_ei(
      ctx.complex(ctx.from_int(20), ctx.from_int(70)),
    ),
    "6.104135191115298439736073170125126344665716161551018729207653634346908169301244722960320044804123525294720795045785e+6",
    "-2.732410931051992887229155925698573083366709023184574331341226369425585040904505408342794848907041868393788623075428e+6",
    "2e-99",
  )
  assert_integral_complex_close(
    ctx.complex_exponential_integral_ei(
      ctx.complex(ctx.from_int(20000), ctx.from_int(10)),
    ),
    "-3.255138234032069402493850638874410725961401274105957644341096877512667656478805086605535323227967325596187708350192e+8681",
    "-2.108192999347440352078594242946918764776736964542319688026960804995098537576030123398111327906037626913762861075654e+8681",
    "2e8576",
  )
}

///|
test "complex exponential integral branch constants match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let z = ctx.complex(@mpf.RawMpf::zero(), ctx.from_int(100))
  assert_integral_complex_close(
    ctx.complex_exponential_integral_ei(z),
    "-5.148825142610492144443553905344497850326337919323245803644176679551342795676441252863637110864097696254781737031532e-3",
    "3.133021793683952912583666830444254119326409680228636366871783988863069074052144989496424765126993293895872755441355",
    "2e-107",
  )
  assert_integral_complex_close(
    ctx.complex_exponential_integral_e1(z),
    "5.148825142610492144443553905344497850326337919323245803644176679551342795676441252863637110864097696254781737031532e-3",
    "-8.570859905840325878976552835248764870759719146469454103160603444747332234064009131610060215123774086275331071927438e-3",
    "2e-107",
  )
}

///|
test "real sine and cosine integrals retain large-argument precision" {
  let ctx = MPContext::new(360, Nearest)
  let x = ctx.parse("1e10")
  assert_close_mpf_str(
    ctx.cosine_integral(x),
    "-4.875060251748226537857297739587362446417698291090666460631760231058261035456163496826354680097408642771835485599499e-11",
    "2e-116",
  )
  assert_close_mpf_str(
    ctx.sine_integral(x),
    "1.570796326707584656968511151774753653728154331399083038453782864814777184261211558058486003440165102136343619104952",
    "2e-107",
  )
}

///|
test "complex sine and cosine integrals match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let z = ctx.complex(ctx.from_int(50), ctx.from_int(2))
  assert_integral_complex_close(
    ctx.complex_cosine_integral(z),
    "-1.837828294613306714929216454111355147107986096670399299339060710196632148974098470353841168986078631164733703267067e-2",
    "7.035280802368833619307868559718677725929354940935156659712981954604733971407715806496211382453753809339071205427413e-2",
    "2e-107",
  )
  assert_integral_complex_close(
    ctx.complex_sine_integral(z),
    "1.497884414277228460982272061586019714401681023001409287562623378836390198179267910052775198227622326948527643856367",
    "-1.751500737843744795076002764970455292441318505573072859274907092872501717402136400282728785800474505051330908544783e-2",
    "2e-106",
  )
}

///|
test "complex trigonometric integral negative-half-plane branches match mpmath" {
  let ctx = MPContext::new(360, Nearest)
  let z = ctx.complex(ctx.from_int(-50), ctx.from_int(-2))
  assert_integral_complex_close(
    ctx.complex_cosine_integral(z),
    "-1.837828294613306714929216454111355147107986096670399299339060710196632148974098470353841168986078631164733703267067e-2",
    "-3.071239845566104902269564697682316106937875849965754254377814772761769066572131840563072711517579529888757374459008",
    "2e-106",
  )
  assert_integral_complex_close(
    ctx.complex_sine_integral(z),
    "-1.497884414277228460982272061586019714401681023001409287562623378836390198179267910052775198227622326948527643856367",
    "1.751500737843744795076002764970455292441318505573072859274907092872501717402136400282728785800474505051330908544783e-2",
    "2e-106",
  )
}
