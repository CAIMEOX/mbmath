///|
test "Lambert W special values preserve branch semantics" {
  let ctx = MPContext::new(360, Nearest)
  @debug.assert_eq(ctx.lambert_w(@mpf.RawMpf::zero()), @mpf.RawMpf::zero())
  @debug.assert_eq(
    ctx.lambert_w(@mpf.RawMpf::zero(), branch=-1),
    @mpf.RawMpf::negative_infinity(),
  )
  @debug.assert_eq(
    ctx.lambert_w(@mpf.RawMpf::infinity()),
    @mpf.RawMpf::infinity(),
  )
  assert_true(ctx.lambert_w(@mpf.RawMpf::nan()).is_nan())
  let positive_branch = ctx.complex_lambert_w(
    ctx.complex(@mpf.RawMpf::infinity(), @mpf.RawMpf::zero()),
    branch=1,
  )
  @debug.assert_eq(positive_branch.real, @mpf.RawMpf::infinity())
  assert_close_mpf_str(
    positive_branch.imag,
    "6.2831853071795864769252867665590057683943387987502116419498891846156328125724179972560696506842341359642961730265646133",
    "2e-105",
  )
  let negative_branch = ctx.complex_lambert_w(
    ctx.complex(@mpf.RawMpf::negative_infinity(), @mpf.RawMpf::zero()),
    branch=1,
  )
  @debug.assert_eq(negative_branch.real, @mpf.RawMpf::infinity())
  assert_close_mpf_str(
    negative_branch.imag,
    "9.42477796076937971538793014983850865259150819812531746292483377692344921885862699588410447602635120394644425953984691995",
    "2e-104",
  )
}

///|
test "real Lambert W principal branch matches mpmath" {
  let ctx = MPContext::new(400, Nearest)
  assert_close_mpf_str(
    ctx.lambert_w(ctx.from_int(1)),
    "0.56714329040978387299996866221035554975381578718651250813513107922304579308668456669321944696175229455763802497286678978545235846594007299561",
    "2e-119",
  )
  @debug.assert_eq(ctx.lambert_w(ctx.e()), @mpf.RawMpf::one())
  assert_close_mpf_str(
    ctx.lambert_w(ctx.parse("-0.25")),
    "-0.3574029561813889030688111040559047533165905550760120436276204485896714025961457962896168513444411851497251000312982901436307913761515391568",
    "2e-118",
  )
  assert_close_mpf_str(
    ctx.lambert_w(ctx.from_int(1000)),
    "5.2496028524015962271260563196973062825214723860595928444514654839913622283209428327396931508543477182420303332983704142700116350195082422414",
    "2e-117",
  )
}

///|
test "real Lambert W minus-one branch matches mpmath" {
  let ctx = MPContext::new(400, Nearest)
  assert_close_mpf_str(
    ctx.lambert_w(ctx.parse("-0.25"), branch=-1),
    "-2.15329236411034964916909915009298137553620648531947769588451150772136258465064937894572790953802743911822772009362807372934285806962539134",
    "2e-117",
