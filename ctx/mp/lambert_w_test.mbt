  assert_close_mpf_str(
    ctx.lambert_w(ctx.parse("-1e-50"), branch=-1),
    "-119.91604653543681516583055478359433582143715560576804765585880285547807837610519791893203616078158891862980005278374413280803853730282957528",
    "2e-115",
  )
}

///|
test "complex Lambert W principal and neighboring branches match mpmath" {
  let ctx = MPContext::new(400, Nearest)
  let negative = ctx.complex(ctx.from_int(-4), @mpf.RawMpf::zero())
  assert_barnes_complex_close(
    ctx.complex_lambert_w(negative),
    "0.67881197132094522768887443618357501185134764292381475908716991095670439870028467400522490204333516004364430289804615110959706648231865112456",
    "1.911950781743399368859321618394965926711743401038685827544027241036792013897289499510278585460396176730993834867089294906308791050428439741",
    "2e-117",
  )
  assert_barnes_complex_close(
    ctx.complex_lambert_w(negative, branch=-1),
    "0.67881197132094522768887443618357501185134764292381475908716991095670439870028467400522490204333516004364430289804615110959706648231865112456",
    "-1.911950781743399368859321618394965926711743401038685827544027241036792013897289499510278585460396176730993834867089294906308791050428439741",
    "2e-117",
  )
  assert_barnes_complex_close(
    ctx.complex_lambert_w(negative, branch=1),
    "-0.66743107129800987750064505227299686371061349752421205148171445615091424217992889627057343481401678531956852847965827954427886155847267672405",
    "7.7682745680278308378729185104500268480182495670208863724874967324781827438235691636858482709294384361380422097721114789054341203395128748437",
    "2e-116",
  )
  let z = ctx.complex(ctx.from_int(3), ctx.from_int(4))
  assert_barnes_complex_close(
    ctx.complex_lambert_w(z),
    "1.2815618061237758781516934323663630275983914516069887161471455780210066005362119658771418163946296178568902039963196659901137127948143915377",
    "0.53309522202097107130904031005820296629030530661118293159643646521041123813840751939882802508369046618395319139966923184759790972613872879861",
    "2e-117",
  )
  assert_barnes_complex_close(
    ctx.complex_lambert_w(z, branch=1),
    "-0.11691092896595324364330574603935841751473539350047892374879781620779634013813897983132391767520596054146721996867553788169867383283098902558",
    "5.6188803987128233435445234553195141449054907008437647753855702704279355872700806154656737259886158714418519181670798904690839449021368675024",
    "2e-116",
  )
  assert_barnes_complex_close(
    ctx.complex_lambert_w(z, branch=-1),
    "0.25856740686699741676367554579352263545811548820558583566106548991727055881863241529804605109364435453745301644424108757303638773088026397679",
    "-3.8521166861614355895275575519001113053590010232257691677066334970769277900714555764692207444314153720758108798509056911937021186456110309439",
    "2e-116",
  )
}

///|
test "Lambert W high and near-zero branches match mpmath" {
  let ctx = MPContext::new(400, Nearest)
  assert_barnes_complex_close(
    ctx.complex_lambert_w(
      ctx.complex(ctx.from_int(1000), @mpf.RawMpf::zero()),
      branch=5,
    ),
    "3.5010625305312891882251360495845067957227306803825649640265151482708451712817153312814645836216001045849437051026560127313704535776725512747",
    "29.961454894118132844406699985355597713751349044954658543627112780023592308425837490519615860836909020092135064668693887420382958956793538236",
    "2e-115",
  )
  assert_barnes_complex_close(
    ctx.complex_lambert_w(
      ctx.complex(ctx.parse("1e-50"), @mpf.RawMpf::zero()),
      branch=1,
    ),
    "-119.91639831441333019102292272820916159370413737380314446491096228703183366205403990664157872186325889653483153521962278655584202968161471038",
    "3.1680049565757507475000308832866113163479988880168197145711063700408812073493403390057598696613650111333366134518247346494076586570159760327",
    "2e-114",
  )
  assert_barnes_complex_close(
    ctx.complex_lambert_w(
      ctx.complex(ctx.from_int(1), @mpf.RawMpf::zero()),
      branch=100000000,
    ),
    "-20.25855780786171142105334605034252234918652629039343985995435231728862708345794549567236611319178327493815354964361697174541674008998542956",
    "628318529.14716228865513582647732177569026238488874811851276508754463032025662051266216789028456477905821090646709389061798375016501123417413",
    "2e-108",
  )
}

///|
test "Lambert W resolves the square-root branch point at high precision" {
  let ctx = MPContext::new(500, Nearest)
  let input_context = MPContext::new(900, Nearest)
  let boundary = input_context.div(
    @mpf.RawMpf::negative_one(),
    input_context.e(),
  )
  let delta = input_context.parse("1e-100")
  let above = input_context.add(boundary, delta)
  let below = input_context.sub(boundary, delta)
  assert_close_mpf_str(
    ctx.lambert_w(above),
    "-0.9999999999999999999999999999999999999999999999999766835601840287579663646393783159912361976370081242969887075994585889235250381833491402172318514691195516830868954215586",
    "2e-145",
  )
  assert_close_mpf_str(
    ctx.lambert_w(above, branch=-1),
    "-1.0000000000000000000000000000000000000000000000000233164398159712420336353606216840087638023629918760654488695284141091245132913303391928170677610242083916458421216083183",
    "2e-145",
  )
  let below_value = ctx.complex_lambert_w(
    ctx.complex(below, @mpf.RawMpf::zero()),
  )
  assert_close_mpf_str(
    below_value.real,
    "-0.99999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999981878121143606365097598083524315583348285019375333602833553549148506156",
    "2e-145",
  )
  assert_close_mpf_str(
    below_value.imag,
    "0.000000000000000000000000000000000000000000000000023316439815971242033635360621684008763802362991875884230080964477760100494126573495026299917954777540546719148628373869120386840110723106018668206544914675891040999492642",
    "2e-195",
  )
  let below_minus_one = ctx.complex_lambert_w(
    ctx.complex(below, @mpf.RawMpf::zero()),
    branch=-1,
  )
  assert_close_mpf_str(
    below_minus_one.real,
    "-0.99999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999981878121143606365097598083524315583348285019375333602833553549148506156",
    "2e-145",
  )
  assert_close_mpf_str(
    below_minus_one.imag,
    "-0.000000000000000000000000000000000000000000000000023316439815971242033635360621684008763802362991875884230080964477760100494126573495026299917954777540546719148628373869120386840110723106018668206544914675891040999492642",
    "2e-195",
  )
  let imaginary_value = ctx.complex_lambert_w(ctx.complex(boundary, delta))
  assert_close_mpf_str(
    imaginary_value.real,
    "-0.99999999999999999999999999999999999999999999999998351278729299871853151349212185836428346223899289851988424920688359338978805784391367223479943633357134073861615133072575",
    "2e-145",
  )
  assert_close_mpf_str(
    imaginary_value.imag,
    "0.000000000000000000000000000000000000000000000000016487212707001281468486507878141635716537761007101298896962229180057586192777399242161248050757419767426406906768971727399760601615670055260487163209359256445919618349359",
    "2e-195",
  )
}

///|
test "Lambert W results satisfy the defining equation" {
  let ctx = MPContext::new(500, Nearest)
  let z = ctx.complex(ctx.parse("-0.448"), ctx.parse("0.4"))
  for branch in [-7, -1, 0, 1, 9] {
    let value = ctx.complex_lambert_w(z, branch~)
    let residual = value
      .mul(value.exp(560, Nearest), 560, Nearest)
      .sub(z, 560, Nearest)
    assert_close_mpf_str(residual.real, "0", "2e-148")
    assert_close_mpf_str(residual.imag, "0", "2e-148")
  }
}

///|
test "real Lambert W rejects branches with complex values" {
  let ctx = MPContext::new(300, Nearest)
  let inputs = [ctx.from_int(-4), ctx.from_int(1), ctx.from_int(1)]
  let branches = [0, -1, 2]
  for index in 0..<inputs.length() {
    let x = inputs[index]
    let branch = branches[index]
    try ctx.lambert_w(x, branch~) catch {
      ComplexResult(_) => ()
      _ => fail("unexpected real Lambert W branch error")
    } noraise {
      _ => fail("expected a complex Lambert W value")
    }
  }
}
