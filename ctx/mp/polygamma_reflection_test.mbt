///|
test "real polygamma uses reflection in the far left half-plane" {
  let ctx = MPContext::new(420, Nearest)
  let x = ctx.parse("-1000000.25")
  let orders = [1, 2, 5]
  let expected = [
    "19.739207802179467237189815567460571281039182663149298755965032125553631056684521858890218422654338393475682809555690821744902",
    "124.02510672119828070340525883090651830857953965091018395062844537841785456457757380502875345790911751456808900589595105090059",
    "492231.26711055587175947235515003896422010537420499606423672294547709043066065950559332747659183030266418180634401755669002039",
  ]
  for i in 0..<orders.length() {
    assert_close_mpf_str(ctx.polygamma(orders[i], x), expected[i], "2e-112")
  }
}

///|
test "high-order real polygamma retains requested precision" {
  let ctx = MPContext::new(420, Nearest)
  let pi = ctx.pi()
  assert_close_mpf_str(
    ctx.polygamma(50, pi),
    "-1344100348958402765749252447726432491812.6419852731605310557070959892278977530358231523976796261364829810870602990601801795272",
    "2e-82",
  )
  let shifted = ctx.add(pi, ctx.mul(ctx.from_int(14), ctx.e()))
  assert_close_mpf_str(
    ctx.polygamma(50, shifted),
    "-0.0000000000000000018979373955080432162351207310189580199301991988637595288105309084459192030811154933729514378034139595374916223954204664455661",
    "2e-133",
  )
}

///|
test "complex polygamma reflects far-left arguments without recurrence caps" {
  let ctx = MPContext::new(420, Nearest)
  let cases = [
    (
      3,
      ctx.complex(ctx.parse("-1000000.25"), ctx.parse("2.5")),
      "-0.00000000028316914211105041404174229110874526345885229925975867181238045581763666374610343199876427942589111722635536798202922589770982",
      "-0.00023487549274911217417560312762782843150706171927888460843942333426395864293669946150157534866533521409890507420809970303383359",
    ),
    (
      10,
      ctx.complex(ctx.parse("-1000.25"), ctx.parse("0.125")),
      "1686631937943.508968085547464918144539469123631071799352110584633933695335423620938532405478767609703101839609216159915127336",
      "-4129642217988.6319397390583825337719525171958289535614923441086279298229588022630372111564310294263518246862336880318187749084",
    ),
  ]
  for case in cases {
    let value = ctx.complex_polygamma(case.0, case.1)
    assert_close_mpf_str(value.real, case.2, "2e-104")
    assert_close_mpf_str(value.imag, case.3, "2e-104")
  }
}

///|
test "high-order complex polygamma converges without fixed term truncation" {
  let ctx = MPContext::new(420, Nearest)
  let z = ctx.complex(ctx.pi(), ctx.mul(ctx.from_int(14), ctx.e()))
  let value = ctx.complex_polygamma(50, z)
  assert_close_mpf_str(
    value.real,
    "-0.000000000000000052251694115216924897522547215568356575237588951063151324478593773852337000948712565078141519566244333355100834544628569302222",
    "2e-132",
  )
  assert_close_mpf_str(
    value.imag,
    "-0.000000000000000018131570414070101847024141102182053485278621963279804177576652822447289638912980801993414808818116131114101340417161735547141",
    "2e-132",
  )
}

///|
test "complex polygamma reflection is stable at huge imaginary arguments" {
  let ctx = MPContext::new(500, Nearest)
  let digamma = ctx.complex_digamma(
    ctx.complex(ctx.parse("0.25"), ctx.parse("1e9")),
  )
  assert_close_mpf_str(
    digamma.real,
    "20.7232658369464111561515064254926112017427910018256234509665577090305741220167910938738043348936788886281506368504484354840667505962416",
    "2e-132",
    comparison_precision=560,
  )
  assert_close_mpf_str(
    digamma.imag,
    "1.57079632704489661923132169165537644209858469969243572298747229615763134767435449931930076838394915900311918829143119242632125923886495",
    "2e-132",
    comparison_precision=560,
  )
  let higher = ctx.complex_polygamma(
    3,
    ctx.complex(ctx.parse("-0.25"), ctx.parse("1e9")),
  )
  assert_close_mpf_str(
    higher.real,
    "0.00000000000000000000000000000000000449999999999999999531249999999999999979492187499999999800048828124999999478458404541015622932889461517333973380122289061546249930484332",
    "2e-140",
    comparison_precision=560,
  )
  assert_close_mpf_str(
    higher.imag,
    "0.00000000000000000000000000199999999999999999425000000000000000192968749999999999969205729166666666672223917643229166667137781778971354167842862606048583986078769",
    "2e-140",
    comparison_precision=560,
  )
}
