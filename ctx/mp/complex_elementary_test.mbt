///|
fn assert_complex_text_close(
  z : @mpc.RawMpc,
  expected_real : String,
  expected_imag : String,
  tolerance : String,
) -> Unit raise {
  assert_close_mpf_str(z.real, expected_real, tolerance)
  assert_close_mpf_str(z.imag, expected_imag, tolerance)
}

///|
test "complex magnitude argument and conjugation match mpmath" {
  let ctx = MPContext::new(380, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_close_mpf_str(
    ctx.complex_abs(z),
    "1.4577379737113251177185382193863957691303495837214929886125016862169525154991781569163100816132588496391974055",
    "2e-108",
  )
  assert_close_mpf_str(
    ctx.complex_arg(z),
    "-0.54041950027058415544357836460859991013514825146259238811636023340959898198391015308247454866682727563170221714",
    "2e-108",
  )
  @debug.assert_eq(
    ctx.complex_conjugate(z),
    ctx.complex(ctx.parse("1.25"), ctx.parse("0.75")),
  )
}

///|
test "complex exponential and trigonometric family match mpmath" {
  let ctx = MPContext::new(380, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_complex_text_close(
    ctx.complex_exp(z),
    "2.5538450905269614463181121825521750721237059530224075613519201672029534885554951732463961910126866889859681152",
    "-2.3791530455804665474679304251258956896363947847169055843101166594603686149348733036283530969056665139337712253",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_sin(z),
    "1.2286345240950955221921460651577759387061635360001846132734304738548307558619091262100904644090605746121803749",
    "-0.25929485455116277915334983061843302759974575379669224812688966950659135490213584966228141529932624134313423517",
    "2e-108",
  )
  assert_complex_text_close(
    ctx.complex_cos(z),
    "0.40824259187796880778885214639749908437299608344874155809866246848237984556216782371987557219612521982125245385",
    "0.78036593084585324039132621630086315223557902413633907498664801215909085691248105856162004255066107139868399959",
    "2e-108",
  )
  assert_complex_text_close(
    ctx.complex_tan(z),
    "0.38579595260975066417759676072079022048438029371762870507232089853299624783431849806349430691039744167827249808",
    "-1.3726075705337832025804860657122685722216034935768286008702379401482191254043529711843081722014436203517778265",
    "2e-107",
  )
}

///|
test "complex hyperbolic family match mpmath" {
  let ctx = MPContext::new(380, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_complex_text_close(
    ctx.complex_sinh(z),
    "1.1721063598927025610108128511613886260410665613303507064486918314225889328626824801370538198722278270172917147",
    "-1.2872229100264918857587351079056544070659921996510549300986973497807107252015394167583173709380781873386513833",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_cosh(z),
    "1.3817387306342588853072993313907864460826393916920568549032283357803645556928126931093423711404588619686764005",
    "-1.091930135553974661709195317220241282570402585065850654211419309679657889733333886870035725967588326595119842",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_tanh(z),
    "0.97536328503123564619358175975521637896721309816226554455306584471097024221974324512117958796448024731340727261",
    "-0.16080778591620642672516605817343866316212214904084979727758551180381617633009574946758388697417529901189140372",
    "2e-108",
  )
}

///|
test "complex inverse functions preserve principal branches" {
  let ctx = MPContext::new(380, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_complex_text_close(
    ctx.complex_asin(z),
    "0.91173829096848763635848956431673120717538921639219555206069803744724163181206286086288307744953656779808332308",
    "-1.0317185344477802733636405863100659357282957249416962499180163463829514214237049558901765032017901630341469559",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_acos(z),
    "0.65905803582640898287283212732302023492319548329535735842677425870666657133104163845113433522152196619299072017",
    "1.0317185344477802733636405863100659357282957249416962499180163463829514214237049558901765032017901630341469559",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_atan(z),
    "0.99682512646391866609890224131044670785095264263922472259774253698934133627830391088172057653529982449199319138",
    "-0.26149213879567192707865205736653213977370241060185726180646679263238126991648772149986171755791979300313769005",
    "2e-108",
  )
  assert_complex_text_close(
    ctx.complex_asinh(z),
    "1.132393631605308195222663336968344665867280063940889949772797207525098275205652829991665838536934960033025613",
    "-0.45327617763879391344892119610197174855280564045340094662433016669250725999843675850781920422522505682934316686",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_acosh(z),
    "1.0317185344477802733636405863100659357282957249416962499180163463829514214237049558901765032017901630341469559",
    "-0.65905803582640898287283212732302023492319548329535735842677425870666657133104163845113433522152196619299072017",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_atanh(z),
    "0.54930614433405484569762261846126285232374527891137472586734716681874714660930448343680787740686604439398501453",
    "-1.107148717794090503017065460178537040070047645401432646676539207433710338977362794013417128686170641434544191",
    "2e-107",
  )
  let outside = ctx.complex(ctx.from_int(2), @mpf.RawMpf::zero())
  assert_complex_text_close(
    ctx.complex_asin(outside),
    "1.5707963267948966192313216916397514420985846996875529104874722961539082031431044993140174126710585339910740433",
    "-1.3169578969248167086250463473079684440269819714675164797684722569204601854164439760742190134501017835564654365656048245928367",
    "2e-107",
  )
  let large_negative = ctx.complex(ctx.parse("-1e100"), @mpf.RawMpf::zero())
  assert_complex_text_close(
    ctx.complex_asinh(large_negative),
    "-230.951656479964513711216377589894597328185648997237552857453470106250654589704942739205583835956248521738779885249209602",
    "0",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_acosh(ctx.complex(ctx.from_int(-2), @mpf.RawMpf::zero())),
    "1.31695789692481670862504634730796844402698197146751647976847225692046018541644397607421901345010178355646543656560482459",
    "3.14159265358979323846264338327950288419716939937510582097494459230781640628620899862803482534211706798214808651328279513",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_atanh(ctx.complex(ctx.from_int(2), @mpf.RawMpf::zero())),
    "0.549306144334054845697622618461262852323745278911374725867347166818747146609304483436807877406866044393985014532978932866",
    "-1.57079632679489661923132169163975144209858469968755291048747229615390820314310449931401741267105853399107404325664115331",
    "2e-107",
  )
}

///|
test "complex roots use principal values instead of real odd roots" {
  let ctx = MPContext::new(380, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  assert_complex_text_close(
    ctx.complex_nthroot(z, 5),
    "1.0719985470441825419710322244646360670077777741799680885270712023398485058914654154267885972213084665234615199",
    "-0.1163190885223046487167932915215498665098953358751094976333846216892134196170529784492400968753391668436661585",
    "2e-108",
  )
  assert_complex_text_close(
    ctx.complex_cbrt(z),
    "1.1155136091561039858609991752742854593428244334941095574888026789309540234621464703481419722080261357431858645",
    "-0.20315064143792545605669568178528083475696310549793717173015712100992365740768319321211950926692104744552525212",
    "2e-108",
  )
  let minus_eight = ctx.complex(ctx.from_int(-8), @mpf.RawMpf::zero())
  assert_complex_text_close(
    ctx.complex_cbrt(minus_eight),
    "1",
    "1.7320508075688772935274463415058723669428052538103806280558069794519330169088000370811461867572485756756261414",
    "2e-108",
  )
  try ctx.complex_nthroot(z, 0) catch {
    ValueError(_) => ()
    _ => fail("unexpected complex root error")
  } noraise {
    _ => fail("expected zero complex root index error")
  }
}

///|
test "complex pi-scaled and imaginary exponential helpers match mpmath" {
  let ctx = MPContext::new(380, Nearest)
  let z = ctx.complex(ctx.parse("1.25"), ctx.parse("-0.75"))
  let (cos_pi_z, sin_pi_z) = ctx.complex_cos_sin_pi(z)
  assert_complex_text_close(
    sin_pi_z, "-3.763754139500834801020261144732957207561620890507867902574416885837033889812121244951161006507291885474018885",
    "3.6967343997925614336532134080019497573718760306555692652289813777609844670274974112324886474625646176751003153",
    "2e-106",
  )
  assert_complex_text_close(
    cos_pi_z, "-3.763754139500834801020261144732957207561620890507867902574416885837033889812121244951161006507291885474018885",
    "-3.6967343997925614336532134080019497573718760306555692652289813777609844670274974112324886474625646176751003153",
    "2e-106",
  )
  @debug.assert_eq(ctx.complex_sin_pi(z), sin_pi_z)
  @debug.assert_eq(ctx.complex_cos_pi(z), cos_pi_z)
  assert_complex_text_close(
    ctx.complex_exp_i(z),
    "0.66753744642913158694220197701593211197274183724543380622555213798897120046430367338215698749545146116438668902",
    "2.0090004549409487625834722814586390909417425601365236882600784860139216127743901847717105069597216460108643745",
    "2e-107",
  )
  assert_complex_text_close(
    ctx.complex_exp_i_pi(z),
    "-7.4604885392933962346734745527349069649334969211634371678033982635980183568396186561836496539698565031491192003",
    "-7.4604885392933962346734745527349069649334969211634371678033982635980183568396186561836496539698565031491192003",
    "2e-106",
  )
}
