///|
test "complex zeta retains 1600-bit precision in the critical strip" {
  let ctx = MPContext::new(1600, Nearest)
  let s = ctx.complex(ctx.parse("0.25"), ctx.from_int(30))
  let value = ctx.complex_zeta(s)
  assert_close_mpf_str(
    value.real,
    "-0.",
    "2e-470",
    comparison_precision=1700,
  )
  assert_close_mpf_str(
    value.imag,
    "-0.",
    "2e-470",
    comparison_precision=1700,
  )
}

///|
test "complex zeta reflection preserves high precision" {
  let ctx = MPContext::new(1400, Nearest)
  let s = ctx.complex(ctx.parse("-7.25"), ctx.parse("19.5"))
  let value = ctx.complex_zeta(s)
  assert_close_mpf_str(
    value.real,
    "7545.",
    "2e-405",
    comparison_precision=1500,
  )
  assert_close_mpf_str(
    value.imag,
    "-2303.",
    "2e-405",
    comparison_precision=1500,
  )
}

///|
test "complex eta resolves cancellation beyond 512 bits near its removable point" {
  let input_context = MPContext::new(1800, Nearest)
  let epsilon = input_context.parse("1e-300")
  let s = input_context.complex(@mpf.RawMpf::one(), epsilon)
  let ctx = MPContext::new(1200, Nearest)
  let value = ctx.complex_zeta(s, alt=true)
  assert_close_mpf_str(
    value.real,
    "0.",
    "2e-360",
    comparison_precision=1300,
  )
  assert_close_mpf_str(
    value.imag,
    "1.-301",
    "2e-660",
    comparison_precision=2300,
  )
}

///|
test "complex zeta resolves non-pole zeros of the eta factor" {
  let input_context = MPContext::new(1000, Nearest)
  let lattice_height = input_context.div(
    input_context.mul(input_context.from_int(2), input_context.pi()),
    input_context.ln2(),
  )
  let s = input_context.complex(@mpf.RawMpf::one(), lattice_height)
  let ctx = MPContext::new(500, Nearest)
  let value = ctx.complex_zeta(s)
  assert_close_mpf_str(
    value.real,
    "1.34657954283631703147352981176780370180554405117049568235131929172085126750241265837586474191135157023389104236431832807126599338448020618584399416757966298821403768373365721305087083438707090274437821381525468",
    "2e-145",
    comparison_precision=560,
  )
  assert_close_mpf_str(
    value.imag,
    "0.10988313679626963756661917751406167572204671839842190404361597605243112304572470851145264263327697400106255296430070791153305743597526877477116905475813183475824922902095744218275740992363203797525839074782365",
    "2e-145",
    comparison_precision=560,
  )
}
