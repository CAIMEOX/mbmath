///|
test "real zeta converges throughout the critical strip" {
  let ctx = MPContext::new(640, Nearest)
  let inputs = ["0.25", "0.5", "0.9"]
  let expected = [
    "-0.813278405261891656521447820073525574481570524529005842605066973442017829724410217101991465229540337098385348805227474500341947217032010268566803851798772026539954991114495598624757950156254485389319004218921172",
    "-1.46035450880958681288949915251529801246722933101258149054288608782553052947450062527641937546335681951449637467986952958389234371035889426181923283975376292518263335864916412789122939415410119791731044810824194",
    "-9.43011401940225237229884978758039343502389581580587061022367382146646118885585881320790529671161125263929009994192691537505298967951102587076697580474316128125679842255790589182098132574938405839253986962482583",
  ]
  for index in 0..<inputs.length() {
    assert_close_mpf_str(
      ctx.zeta(ctx.parse(inputs[index])),
      expected[index],
      "2e-190",
    )
  }
}

///|
test "real eta converges throughout the critical strip" {
  let ctx = MPContext::new(640, Nearest)
  let inputs = ["0.25", "0.5", "0.9"]
  let expected = [
    "0.554487385914073121549352494192895857022041443482700054181450791861059931431411856617800790031343700065109934633247855275036952959705545033994938755262041062848867257646222411812403939561398603140928976856786296",
    "0.604898643421630370247265914235955499759762545130247380378546648082187253495060357327403956918349554383033720410335824053109825223299163504834897013205000061739072732967872328610177617498177335444554360688396993",
    "0.676831935284540509712266593163235958292569922134008108106556122447107607333266981359407509876150728488026667021563788121409190253052668467987549030327227947728434971214600997318182225795960740647523684922691113",
  ]
  for index in 0..<inputs.length() {
    assert_close_mpf_str(
      ctx.eta(ctx.parse(inputs[index])),
      expected[index],
      "2e-190",
    )
  }
}

///|
test "eta near its removable point keeps all requested precision" {
  let ctx = MPContext::new(640, Nearest)
  let input_context = MPContext::new(2400, Nearest)
  let argument = input_context.add(
    @mpf.RawMpf::one(),
    input_context.parse("1e-500"),
  )
  assert_close_mpf_str(
    ctx.eta(argument),
    "0.69314718055994530941723212145817656807550013436025525412068000949339362196969471560586332699641868754200148102057068573368552023575813055703267075163507596193072757082837143519030703862389167347112335",
    "2e-190",
  )
}

///|
test "zeta and eta retain their defining factor relation" {
  let ctx = MPContext::new(640, Nearest)
  for text in ["0.125", "0.75", "1.25", "3.5"] {
    let s = ctx.parse(text)
    let factor = ctx.sub(
      @mpf.RawMpf::one(),
      ctx.pow(ctx.from_int(2), ctx.sub(@mpf.RawMpf::one(), s)),
    )
    assert_close_mpf_str(
      ctx.sub(ctx.eta(s), ctx.mul(factor, ctx.zeta(s))),
      "0",
      "2e-188",
    )
  }
}
